{
  "name": "pwa-skeleton",
  "version": "5.5",
  "private": true,
  "scripts": {
    "dev": "node scripts/kill-port.js && vite --port 5173 --strictPort",
    "dev:mobile": "node scripts/kill-port.js && vite --port 5173 --strictPort --host 0.0.0.0",
    "build": "vite build",
    "build:android:dist": "node scripts/npm-run-build-with-embed-android.mjs",
    "build:capacitor": "npm run build:android:dist",
    "cap:sync:android": "node scripts/cap-sync-android-from-root.mjs",
    "verify:android-bundle": "node scripts/verify-android-bundle.mjs",
    "build:aab": "node scripts/clean-dist-and-android-public.mjs && npm run build:android:dist && node scripts/cap-sync-android-from-root.mjs && cd android && .\\gradlew.bat clean bundleRelease",
    "build:apk": "node scripts/build-apk-pipeline.mjs",
    "install:android": "node scripts/build-apk-pipeline.mjs && cd android && .\\gradlew.bat installDebug",
    "install:apk": "npm run build:apk && cd android && .\\gradlew.bat installDebug",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint \"src/**/*.{ts,tsx}\" && npm run lint:style-guard",
    "lint:style-guard": "node scripts/style-guard.js",
    "new:screen": "node scripts/new-screen.mjs",
    "export:textdoc": "node scripts/generate-text-doc.js",
    "export:textdoc:toc": "node scripts/generate-text-doc-toc.js",
    "export:textdoc:diff": "node scripts/export-textdoc-diff.js",
    "export:textdoc:bereinigt": "node scripts/generate-text-doc-bereinigt.js",
    "export:lektorat": "npx tsx scripts/export-to-docx-trackchanges.ts",
    "generate:sitemap": "node scripts/generate-sitemap.mjs"
  },
  "dependencies": {
    "@capacitor-community/file-opener": "^8.0.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@testing-library/react": "^16.3.2",
    "fuse.js": "^7.1.0",
    "jspdf": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@eslint/js": "^9.39.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "docx": "^9.5.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.0.0",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^1.6.1"
  }
}
